<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/meddevice#"
     xml:base="http://www.example.org/meddevice"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:meddevice="http://www.example.org/meddevice#">
    <owl:Ontology rdf:about="http://www.example.org/meddevice">
        <terms:creator>Eduardo Sánchez Luengo</terms:creator>
        <terms:description xml:lang="en">Ontology for medical devices, manufacturers, incidents, risks and corrective actions under MDR (EU 2017/745) and IVDR (EU 2017/746).</terms:description>
        <terms:title xml:lang="en">MedDevice Ontology</terms:title>
        <rdfs:comment xml:lang="en">Ontology for medical devices, manufacturers, incidents, risks and corrective actions.</rdfs:comment>
        <rdfs:label xml:lang="en">MedDevice Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#affectsDevice">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to the device it affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasFramework -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasFramework">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory framework (functional).</rdfs:comment>
        <rdfs:label xml:lang="en">has framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a device to its manufacturer (functional).</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#involvesDevice">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates an incident to the device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#reportedBy">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#triggeredBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#triggeredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to the incident that triggered it (functional).</rdfs:comment>
        <rdfs:label xml:lang="en">triggered by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#actionDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier of a device (functional).</rdfs:comment>
        <rdfs:label xml:lang="en">device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceName">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial name of a device.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier of an incident (functional).</rdfs:comment>
        <rdfs:label xml:lang="en">incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#isActive">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is active.</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#isImplantable">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether the device is implantable.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#reportDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Device requiring an external energy source.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#CorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/meddevice#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#triggeredBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Action taken after an incident to prevent recurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Country -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Country">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:comment xml:lang="en">Country where a manufacturer is registered.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk related to incorrect diagnostic results.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Entity -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Entity">
        <rdfs:comment xml:lang="en">Root class of the ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#IVDRFramework -->


    <owl:Class rdf:about="http://www.example.org/meddevice#IVDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">In Vitro Diagnostic Regulation (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#ImplantableDevice"/>
        <rdfs:comment xml:lang="en">Device that is both implantable and active.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Device intended to remain in the human body after a procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Device used to examine specimens from the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">IVD Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Incident -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Incident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#involvesDevice"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Event involving a device that may have caused or could cause harm.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#InjuryRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk involving physical injury to a patient or user.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MDRFramework -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Medical Device Regulation (EU 2017/745).</rdfs:comment>
        <rdfs:label xml:lang="en">MDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Manufacturer -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:comment xml:lang="en">Company that produces and places a device on the market.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MedicalDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#hasManufacturer"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device intended for medical use.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#NearMissIncident -->


    <owl:Class rdf:about="http://www.example.org/meddevice#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:comment xml:lang="en">Incident that could have caused harm but did not.</rdfs:comment>
        <rdfs:label xml:lang="en">Near-Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Recall -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Recall">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Corrective action that removes or replaces affected devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#RegulatoryFramework -->


    <owl:Class rdf:about="http://www.example.org/meddevice#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:comment xml:lang="en">European regulatory framework applicable to a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Risk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Risk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:comment xml:lang="en">Potential harm associated with a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#RiskClass -->


    <owl:Class rdf:about="http://www.example.org/meddevice#RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Entity"/>
        <rdfs:comment xml:lang="en">Regulatory risk classification assigned to a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#SafetyAlert -->


    <owl:Class rdf:about="http://www.example.org/meddevice#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Formal safety communication issued by the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#SeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/meddevice#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:comment xml:lang="en">Incident that led or might have led to serious harm or death.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://dbpedia.org/resource/Germany -->


    <owl:NamedIndividual rdf:about="http://dbpedia.org/resource/Germany">
        <owl:sameAs rdf:resource="http://www.example.org/meddevice#Germany"/>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#Germany -->


    <rdf:Description rdf:about="http://www.example.org/meddevice#Germany"/>
    


    <!-- http://dbpedia.org/resource/Medtronic -->


    <owl:NamedIndividual rdf:about="http://dbpedia.org/resource/Medtronic">
        <owl:sameAs rdf:resource="http://www.example.org/meddevice#MAN_001"/>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#MAN_001 -->


    <rdf:Description rdf:about="http://www.example.org/meddevice#MAN_001"/>
    


    <!-- http://dbpedia.org/resource/Republic_of_Ireland -->


    <owl:NamedIndividual rdf:about="http://dbpedia.org/resource/Republic_of_Ireland">
        <owl:sameAs rdf:resource="http://www.example.org/meddevice#Ireland"/>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#Ireland -->


    <rdf:Description rdf:about="http://www.example.org/meddevice#Ireland"/>
    


    <!-- http://www.example.org/meddevice#ACT_001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#ACT_001">
        <rdf:type rdf:resource="http://www.example.org/meddevice#SafetyAlert"/>
        <triggeredBy rdf:resource="http://www.example.org/meddevice#INC_001"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</actionDate>
        <rdfs:comment xml:lang="en">Safety alert triggered by INC_001.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#ClassIII -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#ClassIII">
        <rdf:type rdf:resource="http://www.example.org/meddevice#RiskClass"/>
        <rdfs:comment xml:lang="en">Highest risk class for medical devices under MDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#DEV_001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#DEV_001">
        <rdf:type rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <hasFramework rdf:resource="http://www.example.org/meddevice#MDR"/>
        <hasManufacturer rdf:resource="http://www.example.org/meddevice#MAN_001"/>
        <deviceId>DEV-001</deviceId>
        <deviceName>HeartMate 3</deviceName>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isImplantable>
        <rdfs:comment xml:lang="en">Implantable active ventricular assist device.</rdfs:comment>
        <rdfs:label xml:lang="en">HeartMate 3</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#Germany -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#Germany">
        <rdf:type rdf:resource="http://www.example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Country of registration for Roche Diagnostics GmbH.</rdfs:comment>
        <rdfs:label xml:lang="en">Germany</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#INC_001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#INC_001">
        <rdf:type rdf:resource="http://www.example.org/meddevice#SeriousIncident"/>
        <involvesDevice rdf:resource="http://www.example.org/meddevice#DEV_001"/>
        <incidentId>INC-001</incidentId>
        <reportDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-01-01</reportDate>
        <rdfs:comment xml:lang="en">Serious incident involving DEV_001.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#IVDR -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#IVDR">
        <rdf:type rdf:resource="http://www.example.org/meddevice#IVDRFramework"/>
        <rdfs:comment xml:lang="en">In Vitro Diagnostic Regulation (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#Ireland -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#Ireland">
        <rdf:type rdf:resource="http://www.example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Country of registration for Medtronic plc.</rdfs:comment>
        <rdfs:label xml:lang="en">Ireland</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/meddevice#MAN_001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/meddevice#MAN_001">
